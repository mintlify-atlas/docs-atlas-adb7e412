  "keyFeatures": [
    "Joint and problem management for rehabilitation tracking",
    "Therapeutic exercise library with images, videos, and difficulty levels",
    "Comprehensive exercise categorization (body area, type, position, movement, equipment)",
    "Patient prescription creation with per-exercise custom parameters",
    "React frontend with Tailwind CSS and react-query",
    "SQLite/PostgreSQL/MySQL database support via SQLAlchemy",
    "Full CRUD REST API built with FastAPI and Pydantic v2"
  ],
  "publicApiSurface": [
